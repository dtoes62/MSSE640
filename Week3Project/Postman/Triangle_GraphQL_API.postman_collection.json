              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            },
            "description": "Sends a GraphQL request with no Authorization header. Expects HTTP 401 — verifies auth enforcement is working."
          }
        }
      ]
    }
  ],
